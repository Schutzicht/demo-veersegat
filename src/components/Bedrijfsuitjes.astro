---
import Icon from "./Icon.astro";

const programs = [
  {
    duration: "Halve dag",
    title: "Kennismaking met zeilen",
    body: "Drie uur op het water, drie boten, een korte instructie en daarna alle bemanningsrotaties die je team nodig heeft om elkaar anders te zien.",
    bullets: ["8 – 24 personen", "Instructie aan boord", "Koffie & koek op de steiger"],
  },
  {
    duration: "Hele dag",
    title: "Teamzeilen met regatta",
    body: "Ochtend les, middag wedstrijdje varen tussen de boeien. Eindigt met prijsuitreiking in onze loods, garnalenbroodje optioneel.",
    bullets: ["12 – 36 personen", "Per team een instructeur", "Inclusief lunch & podium"],
  },
];
---

<section id="bedrijfsuitjes" class="bg-(--color-ink) text-(--color-sail) scroll-mt-20">
  <div class="container-vg py-20 md:py-32">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <header class="lg:col-span-5 space-y-6 lg:sticky lg:top-28" data-reveal>
        <div class="eyebrow text-(--color-foam)">Bedrijfsuitjes</div>
        <h2 class="font-display text-[clamp(1.85rem,5vw,3.4rem)] leading-[1.04] tracking-[-0.04em]">
          Een dag op het water is geen teambuilding, het is een vorm van eerlijkheid.
        </h2>
        <p class="text-(--color-foam) max-w-md leading-relaxed">
          Zes Zeeuwse bedrijven en drie multinationals leggen jaarlijks bij ons aan. We organiseren halve of hele dagen, dragen alle bemanning aan, en zorgen voor catering die niet uit een groothandel komt.
        </p>
        <div class="flex flex-wrap items-center gap-4 pt-2">
          <a href="#contact" class="btn-invert">
            Vraag offerte aan
            <Icon name="arrow-right" size={16} />
          </a>
          <a href="tel:+31118501398" class="link-arrow text-(--color-sail) border-(--color-foam)/40 hover:border-(--color-sail)">
            <Icon name="phone" size={14} />
            0118 - 501 398
          </a>
        </div>
      </header>

      <div class="lg:col-span-7 space-y-4">
        {programs.map((p) => (
          <article class="rounded-(--radius-card) border border-(--color-foam)/15 p-6 md:p-8 hover:border-(--color-foam)/35 transition-colors" data-reveal>
            <div class="flex items-center justify-between gap-3 mb-4">
              <span class="text-[0.66rem] uppercase tracking-[0.16em] text-(--color-foam)">{p.duration}</span>
              <Icon name="sail" size={20} class="text-(--color-foam)/60" />
            </div>
            <h3 class="font-display text-2xl md:text-[1.7rem] leading-tight tracking-[-0.03em]">{p.title}</h3>
            <p class="text-(--color-foam) mt-3 text-[0.95rem] leading-relaxed">{p.body}</p>
            <ul class="mt-6 grid sm:grid-cols-3 gap-3 text-sm">
              {p.bullets.map((b) => (
                <li class="flex items-start gap-2 text-(--color-foam-2)">
                  <Icon name="check" size={15} class="text-(--color-foam) mt-0.5 shrink-0" />
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
