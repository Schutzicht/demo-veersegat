---
import Icon from "./Icon.astro";
---

<footer class="surface-deep relative overflow-hidden border-t border-(--color-line)">
  <div class="container-vg pt-16 md:pt-20 pb-12 md:pb-14 relative">
    <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-start">
      <div class="md:col-span-5 space-y-5">
        <div class="flex items-center gap-3">
          <img src="/brand/mark.svg" alt="" width="44" height="44" class="w-10 h-10 md:w-11 md:h-11 shrink-0" />
          <div class="font-display font-semibold text-xl md:text-2xl leading-tight tracking-[-0.03em]">Zeilschool Het Veerse Gat</div>
        </div>
        <p class="text-sm text-(--color-foam) leading-relaxed max-w-md">
          Sinds 1972 leren wij Zeeland zeilen. Vanuit Veere, op een van de mooiste plekken van Nederland, met erkende instructeurs, een bezielde vloot en een ploeg die het water beter kent dan z'n eigen achtertuin.
        </p>
        <div class="flex flex-wrap items-center gap-3 pt-3">
          <img src="/badges/watersportverbond.png" alt="Watersportverbond erkende opleidingslocatie" width="78" height="78" class="h-14 md:h-16 w-auto opacity-90 bg-(--color-sail) rounded-md p-1.5" />
          <img src="/badges/watersport-academy.png" alt="Watersport Academy partner" width="78" height="78" class="h-14 md:h-16 w-auto opacity-90 bg-(--color-sail) rounded-md p-1.5" />
        </div>
      </div>

      <div class="md:col-span-3 space-y-4 text-sm">
        <div class="eyebrow text-(--color-foam)/70">Bezoek</div>
        <a href="https://maps.google.com/?q=Polredijk+21+Veere" target="_blank" rel="noopener" class="flex items-start gap-2.5 text-(--color-foam-2) hover:text-(--color-sail) transition-colors">
          <Icon name="pin" size={18} />
          <span>Polredijk 21<br/>4351 RT Veere</span>
        </a>
        <div class="text-(--color-foam) text-xs leading-relaxed pt-1">
          <div>Mrt - okt: dagelijks open</div>
          <div>Receptie: 09:00 – 17:00</div>
        </div>
      </div>

      <div class="md:col-span-4 space-y-4 text-sm">
        <div class="eyebrow text-(--color-foam)/70">Contact</div>
        <div class="flex flex-col gap-2.5">
          <a href="tel:+31118501398" class="flex items-center gap-2.5 text-(--color-foam-2) hover:text-(--color-sail) transition-colors">
            <Icon name="phone" size={18} />
            <span class="tabular">0118 - 501 398</span>
          </a>
          <a href="mailto:info@veersegat.nl" class="flex items-center gap-2.5 text-(--color-foam-2) hover:text-(--color-sail) transition-colors">
            <Icon name="mail" size={18} />
            <span>info@veersegat.nl</span>
          </a>
        </div>
        <div class="flex items-center gap-3 pt-2">
          <a href="https://www.facebook.com/zeilschoolhetveersegat" target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-(--color-foam)/30 grid place-items-center text-(--color-sail) hover:bg-(--color-sail) hover:text-(--color-ink) hover:border-(--color-sail) transition-colors" aria-label="Facebook">
            <Icon name="facebook" size={18} />
          </a>
          <a href="https://wa.me/31118501398" target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-(--color-foam)/30 grid place-items-center text-(--color-sail) hover:bg-(--color-sail) hover:text-(--color-ink) hover:border-(--color-sail) transition-colors" aria-label="WhatsApp">
            <Icon name="whatsapp" size={18} />
          </a>
        </div>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-(--color-foam)/15 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-(--color-foam)/70">
      <div>© <span class="tabular">{new Date().getFullYear()}</span> Zeilschool Het Veerse Gat · Veere, Zeeland</div>
      <div class="flex items-center gap-4">
        <a href="/beheer" class="hover:text-(--color-sail) transition-colors">Beheer</a>
        <span>Demo-ontwerp door <a href="https://agensea.nl" target="_blank" rel="noopener" class="hover:text-(--color-sail) transition-colors">Agensea.nl</a></span>
      </div>
    </div>
  </div>
</footer>
