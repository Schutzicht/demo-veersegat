---
import Icon from "./Icon.astro";
---

<section class="relative overflow-hidden bg-(--color-ink) text-(--color-sail)">
  <!-- Achtergrondbeeld -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src="/photos/zonsondergang.jpg"
      alt=""
      class="w-full h-full object-cover object-[center_55%]"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(14,18,22,0.55) 0%, rgba(14,18,22,0.35) 40%, rgba(14,18,22,0.7) 100%);"></div>
  </div>

  <div class="container-vg relative pt-36 md:pt-52 pb-16 md:pb-24">
    <div class="max-w-4xl">
      <div class="text-[0.72rem] uppercase tracking-[0.2em] text-(--color-foam) mb-6" data-reveal data-i18n="header.subtitle">
        Veere · sinds 1972
      </div>

      <h1 class="font-display text-[clamp(2.4rem,8vw,5.6rem)] leading-[0.98] tracking-[-0.045em] text-balance" data-reveal>
        <span data-i18n="hero.title.line1">Leer zeilen op het</span>
        <span data-i18n="hero.title.lake"> Veerse Meer</span><span data-i18n="hero.title.line3">.</span>
      </h1>

      <p class="text-base md:text-xl text-(--color-foam-2) max-w-2xl leading-relaxed mt-7" data-reveal data-i18n="hero.body">
        Vijf minuten van de oude havenkom leiden we al meer dan vijftig jaar zeilers op. Kinderen die voor het eerst de giek ontwijken, volwassenen die hun CWO halen, families die een week op het water willen wonen. Klein, eigenwijs, en met een vloot die er staat.
      </p>

      <div class="flex flex-wrap items-center gap-4 pt-9" data-reveal>
        <a href="#agenda" class="btn-invert">
          <span data-i18n="hero.cta.primary">Bekijk beschikbaarheid</span>
          <Icon name="arrow-right" size={16} />
        </a>
        <a href="#zeilschool" class="link-arrow text-(--color-sail) border-(--color-foam)/40 hover:border-(--color-sail)">
          <span data-i18n="hero.cta.secondary">Hoe wij lesgeven</span>
          <Icon name="arrow-right" size={14} />
        </a>
      </div>
    </div>

    <!-- Rustige statistiek-rij -->
    <div class="mt-16 md:mt-24 pt-8 border-t border-(--color-sail)/15 grid grid-cols-3 gap-6 max-w-2xl" data-reveal>
      <div>
        <div class="font-display text-3xl md:text-4xl tabular">53</div>
        <div class="text-[0.68rem] uppercase tracking-[0.16em] text-(--color-foam)/70 mt-1.5" data-i18n="hero.stat.years">jaar les</div>
      </div>
      <div>
        <div class="font-display text-3xl md:text-4xl tabular">31</div>
        <div class="text-[0.68rem] uppercase tracking-[0.16em] text-(--color-foam)/70 mt-1.5" data-i18n="hero.stat.boats">boten</div>
      </div>
      <div>
        <div class="font-display text-3xl md:text-4xl tabular">8</div>
        <div class="text-[0.68rem] uppercase tracking-[0.16em] text-(--color-foam)/70 mt-1.5" data-i18n="hero.stat.instructors">instructeurs</div>
      </div>
    </div>
  </div>
</section>

<!-- Rustige certificeringsregel -->
<div class="border-b border-(--color-line) bg-(--color-sail-2)">
  <div class="container-vg py-5 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-[0.7rem] uppercase tracking-[0.14em] text-(--color-ink-soft)">
    <span>Watersportverbond erkend</span>
    <span class="hidden sm:inline text-(--color-line-2)">·</span>
    <span>CWO niveau I &ndash; III</span>
    <span class="hidden sm:inline text-(--color-line-2)">·</span>
    <span>Watersport Academy partner</span>
    <span class="hidden md:inline text-(--color-line-2)">·</span>
    <span class="hidden md:inline">4.8 / 5 · 312 reviews</span>
  </div>
</div>
