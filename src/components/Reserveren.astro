---
import Icon from "./Icon.astro";
---

<!-- Gedeelde reserveer-modal voor verblijf & bootverhuur. Eén aanvraag, landt
     in dezelfde beheerkant als de zeilkamp-inschrijvingen. -->
<div data-res-modal class="modal-backdrop" role="dialog" aria-modal="true" hidden>
  <div class="modal-card" role="document">
    <button type="button" data-res-close class="absolute top-3 right-3 w-9 h-9 rounded-full grid place-items-center text-(--color-ink-soft) hover:text-(--color-ink) hover:bg-(--color-sand)/40 transition-colors" aria-label="Sluit">
      <Icon name="close" size={18} />
    </button>

    <div data-res-form-wrap class="space-y-4">
      <header class="space-y-1 pr-8">
        <div class="eyebrow text-(--color-signal)" data-res-eyebrow>Beschikbaarheid aanvragen</div>
        <h3 class="font-display text-2xl leading-tight" data-res-title>—</h3>
        <p class="text-sm text-(--color-ink-soft)" data-res-sub>Vul je gegevens in, dan kijkt Karen of het past en mailt je persoonlijk terug.</p>
      </header>

      <form data-res-form class="space-y-3.5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="reg-field">
            <span>Vanaf datum</span>
            <input type="date" name="date" required />
          </label>
          <label class="reg-field">
            <span data-res-qty-label>Aantal</span>
            <input type="number" name="qty" required min="1" max="60" value="1" inputmode="numeric" />
          </label>
        </div>
        <label class="reg-field">
          <span>Naam</span>
          <input type="text" name="naam" required autocomplete="name" />
        </label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="reg-field">
            <span>E-mail</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label class="reg-field">
            <span>Telefoon</span>
            <input type="tel" name="telefoon" required autocomplete="tel" placeholder="06 ..." />
          </label>
        </div>
        <label class="reg-field">
          <span>Opmerking <em class="reg-opt">(optioneel)</em></span>
          <textarea name="note" rows="2" placeholder="bv. ook een bootje erbij, of een vraag"></textarea>
        </label>
        <button type="submit" class="btn-signal w-full justify-center">
          Aanvraag versturen
          <Icon name="arrow-right" size={16} />
        </button>
      </form>
    </div>

    <div data-res-success hidden class="text-center space-y-4 py-3">
      <div class="w-16 h-16 mx-auto rounded-full bg-(--color-ink) text-(--color-sail) grid place-items-center">
        <Icon name="check" size={28} stroke={2.2} />
      </div>
      <h3 class="font-display text-2xl">Aanvraag binnen</h3>
      <p class="text-sm text-(--color-ink-soft) max-w-sm mx-auto leading-relaxed" data-res-success-body>—</p>
      <div class="text-xs text-(--color-ink-soft) tabular">Kenmerk <span data-res-ref class="font-medium">—</span></div>
      <button type="button" data-res-close class="btn-primary mx-auto">Sluit <Icon name="arrow-right" size={16} /></button>
    </div>
  </div>
</div>

<script>
  import { addBooking } from "../data/store";

  const modal = document.querySelector<HTMLElement>("[data-res-modal]");
  if (modal) {
    const form = modal.querySelector<HTMLFormElement>("[data-res-form]")!;
    const formWrap = modal.querySelector<HTMLElement>("[data-res-form-wrap]")!;
    const successWrap = modal.querySelector<HTMLElement>("[data-res-success]")!;
    const titleEl = modal.querySelector<HTMLElement>("[data-res-title]")!;
    const subEl = modal.querySelector<HTMLElement>("[data-res-sub]")!;
    const eyebrowEl = modal.querySelector<HTMLElement>("[data-res-eyebrow]")!;
    const qtyLabel = modal.querySelector<HTMLElement>("[data-res-qty-label]")!;
    const successBody = modal.querySelector<HTMLElement>("[data-res-success-body]")!;
    const refEl = modal.querySelector<HTMLElement>("[data-res-ref]")!;

    let ctx = { kind: "verblijf", key: "", label: "", unit: "nachten" };

    const open = (btn: HTMLElement) => {
      ctx = {
        kind: btn.dataset.kind || "verblijf",
        key: btn.dataset.key || "",
        label: btn.dataset.label || "",
        unit: btn.dataset.unit || "nachten",
      };
      eyebrowEl.textContent = ctx.kind === "boot" ? "Huur aanvragen" : "Beschikbaarheid aanvragen";
      titleEl.textContent = ctx.label;
      subEl.textContent = ctx.kind === "boot"
        ? "Vul je gegevens in voor je huuraanvraag. Voor de zeilboten vragen we even naar je CWO-diploma."
        : "Vul je gegevens in, dan kijkt Karen of het past en mailt je persoonlijk terug.";
      qtyLabel.textContent = ctx.unit === "dagen" ? "Aantal dagen" : ctx.unit === "weken" ? "Aantal weken" : "Aantal nachten";
      form.reset();
      (form.elements.namedItem("qty") as HTMLInputElement).value = "1";
      formWrap.hidden = false;
      successWrap.hidden = true;
      modal.hidden = false;
      requestAnimationFrame(() => modal.classList.add("is-open"));
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      modal.classList.remove("is-open");
      document.body.style.overflow = "";
      setTimeout(() => { modal.hidden = true; }, 280);
    };

    document.querySelectorAll<HTMLElement>("[data-reserveer]").forEach((b) =>
      b.addEventListener("click", () => open(b))
    );
    modal.querySelectorAll<HTMLButtonElement>("[data-res-close]").forEach((b) => b.addEventListener("click", close));
    modal.addEventListener("click", (e) => { if (e.target === modal) close(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && modal.classList.contains("is-open")) close(); });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const get = (n: string) => (form.elements.namedItem(n) as HTMLInputElement)?.value ?? "";
      const booking = addBooking({
        kind: ctx.kind as "verblijf" | "boot" | "groep",
        productKey: ctx.key,
        productLabel: ctx.label,
        naam: get("naam"),
        email: get("email"),
        telefoon: get("telefoon"),
        date: get("date"),
        qty: Number(get("qty")) || 1,
        qtyUnit: ctx.unit,
        note: get("note"),
      });
      successBody.innerHTML = `Je aanvraag voor <strong>${ctx.label}</strong> staat genoteerd. Karen kijkt of het past en mailt of belt je persoonlijk terug.`;
      refEl.textContent = booking.ref;
      formWrap.hidden = true;
      successWrap.hidden = false;
      const toast = document.querySelector<HTMLElement>("[data-toast]");
      const toastMsg = document.querySelector<HTMLElement>("[data-toast-msg]");
      if (toast && toastMsg) { toastMsg.textContent = "Aanvraag verstuurd"; toast.classList.add("is-visible"); setTimeout(() => toast.classList.remove("is-visible"), 2600); }
    });
  }
</script>
