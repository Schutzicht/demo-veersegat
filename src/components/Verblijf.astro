---
import Icon from "./Icon.astro";

const stays = [
  {
    type: "Trekkershut",
    title: "Drie trekkershutten",
    body: "Eenvoudige houten hutten op het terrein, max 6 personen, met gedeelde sanitair-units. Ideaal voor families die de jeugdweek combineren met een korte vakantie.",
    specs: ["6 personen", "Gedeeld sanitair", "Vanaf € 65 / nacht"],
    accent: "var(--color-tide)",
  },
  {
    type: "Appartement",
    title: "Het zeilappartement",
    body: "Boven de loods, met balkon, eigen keukentje en uitzicht over het meer. Twee slaapkamers, slaapt vier personen comfortabel.",
    specs: ["4 personen", "Eigen sanitair", "Vanaf € 145 / nacht"],
    accent: "var(--color-signal)",
  },
];
---

<section id="verblijf" class="container-vg py-16 md:py-28 scroll-mt-20">
  <div class="grid lg:grid-cols-12 gap-8 lg:gap-10 items-end mb-10 md:mb-12" data-reveal>
    <div class="lg:col-span-7 space-y-4">
      <div class="eyebrow">Overnachten op het terrein</div>
      <h2 class="font-display text-[clamp(1.85rem,5.2vw,3.6rem)] leading-[1.02]">
        Blijf <span class="italic">slapen</span>, en hoor 's ochtends de eerste touw-tikken.
      </h2>
      <p class="text-(--color-ink-soft) max-w-xl leading-relaxed">
        Geen luxe-resort. Wel een terrein waar je 's ochtends bij het ontbijt al ziet hoe de wind staat, en waar de kinderen na de cursus zo het water weer in lopen.
      </p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    {stays.map((s) => (
      <article class="surface-paper rounded-(--radius-card) overflow-hidden flex flex-col group hover:border-(--color-ink) transition-colors" data-reveal>
        <div class="relative h-52 md:h-64 overflow-hidden">
          {s.type === "Trekkershut" ? (
            <img src="/photos/zonsondergang.jpg" alt="Trekkershutten aan het Veerse Meer bij zonsondergang" loading="lazy" class="absolute inset-0 w-full h-full object-cover object-[80%_center] scale-[1.05] group-hover:scale-110 transition-transform duration-[1.2s]" />
          ) : (
            <img src="/photos/water-texture.jpg" alt="Het Veerse Meer" loading="lazy" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-[1.2s]" />
          )}
          <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(10,30,51,0) 30%, rgba(10,30,51,0.55) 100%);"></div>
          <span class="absolute top-4 left-4 chip bg-(--color-sail)/95 text-(--color-ink) backdrop-blur">{s.type}</span>
        </div>
        <div class="p-6 md:p-7 flex flex-col gap-4">
          <h3 class="font-display text-2xl">{s.title}</h3>
          <p class="text-(--color-ink-soft) text-[0.95rem] leading-relaxed">{s.body}</p>
          <ul class="flex flex-wrap gap-2 pt-2">
            {s.specs.map((spec) => (
              <li class="chip bg-(--color-sand)/40 text-(--color-ink-soft) border border-(--color-line)">{spec}</li>
            ))}
          </ul>
          <a href="#contact" class="mt-2 link-arrow self-start">
            Beschikbaarheid checken
            <Icon name="arrow-right" size={14} />
          </a>
        </div>
      </article>
    ))}
  </div>
</section>
