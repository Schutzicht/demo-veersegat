---
import Icon from "./Icon.astro";

const pillars = [
  {
    icon: "compass",
    title: "Eigenwijze school",
    body: "Geen lopende band. Acht instructeurs, kleine groepen, en een hoofdinstructeur die elke ochtend de wind ruikt voor we het water op gaan.",
  },
  {
    icon: "sail",
    title: "Drie vloten, één meer",
    body: "Optimist, Laser Pico, Bahia en Valk, voor elke leeftijd en elk niveau het juiste schip. Onderhoud doen we hier op de werf, niet op afstand.",
  },
  {
    icon: "trophy",
    title: "CWO-diploma's",
    body: "Officieel erkend door het Watersportverbond. Vaardigheid wordt getoetst, het diploma krijg je op vrijdagmiddag tussen de moeders en de patat in.",
  },
];
---

<section id="zeilschool" class="container-vg py-16 md:py-28 scroll-mt-20">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
    <header class="lg:col-span-5 space-y-5 lg:sticky lg:top-24" data-reveal>
      <div class="eyebrow">De zeilschool</div>
      <h2 class="font-display text-[clamp(1.85rem,5.2vw,3.4rem)] leading-[1.02]">
        Een school die <span class="">in</span> het water staat, niet ernaast.
      </h2>
      <p class="text-(--color-ink-soft) leading-relaxed max-w-md">
        Wij doen geen massacursussen. Wij doen weekjes waarin een kind op maandag bang is voor het overstag en op vrijdag zelf het commando geeft. Met instructeurs die hier opgegroeid zijn, een werkplaats op het terrein en koffie die altijd te sterk is.
      </p>
      <div class="flex flex-wrap items-center gap-3 pt-2">
        <a href="#agenda" class="btn-primary">
          Naar de cursussen
          <Icon name="arrow-right" size={16} />
        </a>
        <a href="#contact" class="link-arrow">
          Stuur ons een vraag
          <Icon name="arrow-right" size={14} />
        </a>
      </div>
    </header>

    <div class="lg:col-span-7 space-y-5">
      {pillars.map((p, i) => (
        <article class="surface-paper rounded-(--radius-card) p-6 md:p-7 grid grid-cols-[auto_1fr] gap-5 md:gap-6 items-start hover:border-(--color-ink) transition-colors" data-reveal>
          <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl bg-(--color-ink) text-(--color-sail) grid place-items-center">
            <Icon name={p.icon} size={22} />
          </div>
          <div>
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-display text-xl md:text-2xl">{p.title}</h3>
              <span class="text-(--color-ink-soft) tabular text-sm">{String(i + 1).padStart(2, "0")} / 03</span>
            </div>
            <p class="text-(--color-ink-soft) leading-relaxed mt-2 text-[0.95rem]">{p.body}</p>
          </div>
        </article>
      ))}

      <!-- Quote / portret met foto -->
      <article class="rounded-(--radius-card) bg-(--color-ink) text-(--color-sail) relative overflow-hidden grid md:grid-cols-5" data-reveal>
        <div class="md:col-span-2 relative aspect-[4/3] md:aspect-auto md:min-h-[320px]">
          <img src="/photos/herfstweek.jpg" alt="Cursisten in een Bahia op het Veerse Meer" loading="lazy" class="absolute inset-0 w-full h-full object-cover object-[right_center]" />
          <div class="absolute inset-0 md:bg-gradient-to-r md:from-transparent md:to-(--color-ink)/70 bg-gradient-to-t from-(--color-ink)/80 to-transparent" aria-hidden="true"></div>
          <div class="absolute bottom-3 left-3 right-3 md:hidden flex flex-wrap gap-1.5">
            <span class="chip bg-(--color-sail)/95 text-(--color-ink) text-[0.6rem]">CWO Instructeur III</span>
          </div>
        </div>
        <div class="md:col-span-3 p-7 md:p-9 relative flex flex-col">
          <div class="eyebrow text-(--color-foam)">Hoofdinstructeur</div>
          <svg viewBox="0 0 36 36" class="w-7 h-7 text-(--color-foam)/25 mt-4" aria-hidden="true">
            <path d="M11 8 C6 8 4 12 4 16 C4 20 7 23 11 23 V18 H8 V16 C8 13 9 11 12 11 Z M27 8 C22 8 20 12 20 16 C20 20 23 23 27 23 V18 H24 V16 C24 13 25 11 28 11 Z" fill="currentColor"/>
          </svg>
          <blockquote class="font-display font-medium text-2xl md:text-[1.7rem] leading-[1.2] tracking-[-0.03em] mt-3 flex-1">
            Zeilen leren is niet een trucje. Het is leren omgaan met iets dat je niet onder controle hebt. Dat duurt langer dan een week, maar we beginnen hier.
          </blockquote>
          <div class="mt-6 pt-5 border-t border-(--color-foam)/15 flex items-start gap-3.5">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-(--color-foam)/20 to-(--color-foam)/5 grid place-items-center shrink-0 ring-1 ring-(--color-foam)/15 overflow-hidden">
              <svg viewBox="0 0 48 48" class="w-full h-full" aria-hidden="true">
                <defs>
                  <linearGradient id="instr-bg" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#1F5B82"/>
                    <stop offset="1" stop-color="#0A1E33"/>
                  </linearGradient>
                </defs>
                <rect width="48" height="48" fill="url(#instr-bg)"/>
                <circle cx="24" cy="19" r="7" fill="#E8DCC1"/>
                <path d="M24 28 C16 28 11 33 10 42 H38 C37 33 32 28 24 28 Z" fill="#E8DCC1"/>
                <path d="M12 14 Q24 6 36 14 V18 Q24 14 12 18 Z" fill="#0A1E33"/>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-(--color-sail) font-medium">Jan-Kees de Looff</div>
              <div class="text-[0.78rem] text-(--color-foam)/70">Sinds 1998 op het Veerse Meer, CWO Instructeur III</div>
              <div class="hidden md:flex flex-wrap gap-1.5 mt-2.5">
                <span class="chip border border-(--color-foam)/25 text-(--color-foam) text-[0.6rem]">CWO Instructeur III</span>
                <span class="chip border border-(--color-foam)/25 text-(--color-foam) text-[0.6rem]">Reddingsdiploma A</span>
                <span class="chip border border-(--color-foam)/25 text-(--color-foam) text-[0.6rem]">VHF-marifoon</span>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
